# Mapbox public token for the native Match Map. Keep the real value in ignored .env.local.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token
# Public Sepolia deployment values. They are addresses/block numbers, never secrets.
EXPO_PUBLIC_MATCH_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_MATCH_REGISTRY_DEPLOYMENT_BLOCK=0
