    "start:lan": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:device": "bash scripts/run-android.sh",
    "android:recover": "CLEAN_PREBUILD=1 REGENERATE_BUNDLES=1 bash scripts/run-android.sh",
